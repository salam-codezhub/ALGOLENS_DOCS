# ==============================
# AlgoLens - Root .gitignore
# ==============================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Build output
dist/
build/
out/
*.tsbuildinfo
.turbo/

# VS Code extension packaging
*.vsix

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing / coverage
coverage/
.nyc_output/

# Local database / cache
*.sqlite
*.sqlite3
*.db
.cache/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode-test/
.idea/
*.swp
*.swo

# Misc
.eslintcache
.stylelintcache
*.tsbuildinfo
