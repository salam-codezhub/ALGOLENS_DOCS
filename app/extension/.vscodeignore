# Source — only the webpack bundle in dist/ ships, not raw TypeScript
src/**
*.ts

# Build tooling / config — not needed at runtime
webpack.config.cjs
tsconfig.json
tsconfig.tsbuildinfo
*.tsbuildinfo

# Type declarations and source maps are useful for debugging/linking but not
# needed at runtime — keep them out of releases for now; revisit in Phase 39
# (Packaging & Release) if we want either shipped.
dist/**/*.d.ts
dist/**/*.d.ts.map
**/*.map

# Standard excludes
.vscode/**
.vscode-test/**
node_modules/**
**/*.log
